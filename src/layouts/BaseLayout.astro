---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { 
  title = "rendoire, Software & AI Engineer",
  description = "Software & AI Engineer for the past 7 years. Business & Technology since childhood. Creativity for a lifetime.",
  canonical = Astro.url.pathname === '/' ? "https://rendoire.com/" : `https://rendoire.com${Astro.url.pathname}`
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "rendoire",
  "url": "https://rendoire.com",
  "jobTitle": "Software & AI Engineer",
  "sameAs": [
    "https://rendoire.medium.com",
    "https://github.com/rhenpri"
  ],
  "knowsAbout": ["AI Systems", "Software Engineering", "Live Service Engineering"]
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="cT6a2uprHKG7X6cYmBHFSFzvUQM1Jztg6mUjX-r6pNs" />
    
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="rendoire writing" href="/feed.xml" />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://rendoire.com/og-image.png" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://rendoire.com/og-image.png" />
    
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.rss2json.com" />
    <link rel="preconnect" href="https://medium.com" />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/logo.png" />
    
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <div class="ambient-bg" aria-hidden="true">
      <div class="ambient-blob amb-p"></div>
      <div class="ambient-blob amb-b"></div>
    </div>

    <slot />

    <script is:inline>
      // Scroll Reveal Logic
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, observerOptions);

      // Initial observation
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Magnetic Card Mouse Glow
      document.addEventListener('mousemove', e => {
        const cards = document.querySelectorAll('.card-polished');
        cards.forEach(card => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          card.style.setProperty('--mouse-x', `${x}px`);
          card.style.setProperty('--mouse-y', `${y}px`);
        });
      });

      // Handle dynamic word animation if it exists on the page
      const initDynamicWord = () => {
        const dynWords = ['build', 'connect', 'code', 'learn', 'design'];
        const dynColors = ['var(--blue)', 'var(--green)', 'var(--purple)', 'var(--amber)', 'var(--mid)'];
        let wordIdx = 0;
        const dynEl = document.getElementById('dynamic-word');

        if (dynEl) {
          setInterval(() => {
            dynEl.style.opacity = '0';
            dynEl.style.transform = 'translateY(-10px)';
            
            setTimeout(() => {
              wordIdx = (wordIdx + 1) % dynWords.length;
              dynEl.innerText = dynWords[wordIdx];
              dynEl.style.color = dynColors[wordIdx];
              dynEl.style.transform = 'translateY(10px)';
              
              void dynEl.offsetWidth; // trigger reflow
              
              dynEl.style.opacity = '1';
              dynEl.style.transform = 'translateY(0)';
            }, 400);
          }, 2500);
        }
      };

      initDynamicWord();
    </script>
  </body>
</html>
