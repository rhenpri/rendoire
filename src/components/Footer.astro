---
import { execSync } from 'child_process';

let buildHash = 'dev';
try {
  buildHash = execSync('git rev-parse --short HEAD').toString().trim();
} catch (e) {}

const buildDate = new Date().toISOString().split('T')[0];
---

<div class="footer-nudge reveal">
  <p>Get new writing straight to your inbox.</p>
  <a href="https://rendoire.medium.com/subscribe" target="_blank" rel="noopener">Subscribe ↗</a>
</div>

<footer>
  <div class="footer-top">
    <span>&copy; {new Date().getFullYear()} rendoire. Created & imagineerd in 🇮🇪</span>
    <span class="license">Content licensed under <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC-BY 4.0</a>.</span>
  </div>
  
  <div class="footer-links">
    <a href="/feed.xml">RSS Feed</a>
    <a href="/sitemap-index.xml">Sitemap</a>
  </div>

  <div class="footer-bottom">
    <div></div>
    <span class="build-info">build:{buildHash} :: {buildDate}</span>
  </div>
</footer>

<style>
.footer-nudge {
  text-align: center;
  padding: 5rem 1.5rem;
  border-top: 1px solid var(--border);
}
.footer-nudge p {
  font-family: var(--fd);
  font-size: clamp(2rem, 5vw, 3rem);
  margin-bottom: 2rem;
  color: var(--text);
  letter-spacing: 0.02em;
}
.footer-nudge a {
  display: inline-block;
  font-family: var(--fm);
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #000;
  background: var(--amber);
  padding: 0.85rem 2.5rem;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  transition: background 0.2s, transform 0.2s;
}
.footer-nudge a:hover {
  background: #ffcc66;
  transform: translateY(-2px);
}

footer {
  padding: 3rem 3rem 2rem;
  border-top: 1px solid var(--border);
  display: flex; flex-direction: column; gap: 2rem;
}
.footer-top {
  display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: .5rem;
}
.footer-top span { font-family: var(--fm); font-size: 0.65rem; color: var(--muted); }
.license a { color: var(--muted); text-decoration: underline; transition: color 0.2s; }
.license a:hover { color: var(--text); }

.footer-links {
  display: flex;
  gap: 1.5rem;
  font-family: var(--fm);
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.footer-links a { color: var(--mid); transition: color 0.2s; text-decoration: none; padding: 0.5rem 0; }
.footer-links a:hover { color: var(--amber); }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 1rem;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  padding-top: 1.5rem;
}
.build-info {
  font-family: var(--fm);
  font-size: 0.6rem;
  color: var(--muted);
  letter-spacing: 0.1em;
}
.gh-badge { display: flex; align-items: center; }
</style>
