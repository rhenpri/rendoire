---
import { Picture } from 'astro:assets';
import cadeImg from '../assets/cade.png';
import ProjectStack from './react/ProjectStack.tsx';

const projects = [
  {
    num: '001',
    name: 'cade.golf',
    desc: 'A social golf app for Irish golfers. Log your rounds, track your mates, discover courses, and settle arguments mid-round. Phase 1 is live.',
    link: 'https://cade.golf',
    linkText: 'Visit cade.golf ↗',
    color: 'g',
    diagram: 'golf',
    stack: ['Astro', 'TypeScript', 'Node.js', 'PostgreSQL']
  },
  {
    num: '002',
    name: 'Self-Hosted AI',
    desc: 'Designed and built complete AI systems on hardware I own and manage. Language models, agent frameworks, reasoning pipelines, and automation networks, all running privately.',
    color: 'b',
    diagram: 'ai',
    stack: ['Proxmox', 'Ollama', 'n8n', 'Tailscale']
  },
  {
    num: '003',
    name: 'Software Engineer - Live Service',
    desc: 'Handling high-stakes incident response, observability, and production tooling. Hard-won expertise in keeping complex, distributed systems alive in production.',
    color: 'p',
    diagram: 'ops',
    stack: ['Go', 'Kubernetes', 'Datadog', 'Terraform']
  },
  {
    num: '004',
    name: 'AI Education',
    desc: 'Built and delivered workshops, written content, and digital learning materials to teach AI and Agents to practitioners. Co-founded a programme that ran cohort training.',
    color: 'a',
    diagram: 'edu',
    stack: ['Python', 'Langchain', 'Jupyter', 'Vercel']
  }
];
---

<section id="projects">
  <div class="s-label label-p">03 / Projects</div>
  <h2 class="s-title reveal">Recent Work</h2>

  <ProjectStack client:visible projects={projects.map(p => ({ ...p, imageSrc: cadeImg.src }))} />
</section>

<style>
  .tech-diagram {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at center, rgba(255,255,255,0.03), transparent 70%);
  }
  .tech-diagram svg {
    width: 240px;
    height: auto;
    filter: drop-shadow(0 0 12px currentColor);
  }
  .diag-g { color: var(--green); }
  .diag-b { color: var(--blue); }
  .diag-p { color: var(--purple); }
  .diag-a { color: var(--amber); }

  .proj-stack {
    font-family: var(--fm);
    font-size: 0.65rem;
    color: var(--muted);
    letter-spacing: 0.05em;
    margin-top: -0.5rem;
    margin-bottom: 1.5rem;
  }
</style>
